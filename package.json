{
  "name": "garmin-bud",
  "version": "0.2.0",
  "description": "GarminBud — talk to your Garmin Connect data through Claude and other MCP clients",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "QUICKSTART.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ],
  "bin": {
    "garmin-bud": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts start",
    "start": "node dist/index.js start",
    "test": "node --import tsx --test tests/auth.test.ts tests/cache.test.ts tests/tools.test.ts tests/integration.test.ts tests/mcpConfig.test.ts tests/rawApi.test.ts tests/httpServer.test.ts",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "garmin",
    "garmin-connect",
    "mcp",
    "model-context-protocol",
    "claude",
    "fitness",
    "health",
    "garminbud"
  ],
  "author": "Zsadigzade",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zsadigzade/garmin-bud.git"
  },
  "homepage": "https://github.com/Zsadigzade/garmin-bud#readme",
  "bugs": {
    "url": "https://github.com/Zsadigzade/garmin-bud/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "garmin-connect": "^1.6.2",
    "luxon": "^3.7.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  }
}
